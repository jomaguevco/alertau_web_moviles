# =====================================================================
#  PLANTILLA DE VARIABLES DE ENTORNO  -  AlertaU Web
#
#  LOCAL:  copia este archivo como  .env  y pon tus datos de MySQL local.
#  NUBE:   define estas mismas variables en el panel del hosting
#          (Railway / Render / etc.). NO subas el archivo .env (esta en .gitignore).
# =====================================================================

# --- Base de datos ---
# Valores por defecto para XAMPP en Windows (usuario root sin contrasena):
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=incidencias_campus
DB_PORT=3306

# Poner en true SOLO si el proveedor de BD exige TLS (Aiven, TiDB).
# En MySQL local (XAMPP) o en la red interna de Railway: false
DB_SSL=false

# --- Seguridad ---
# Clave para firmar la cookie de sesion del login web. Cambiala en produccion.
SECRET_KEY=ALERTAU2026$$**campus
