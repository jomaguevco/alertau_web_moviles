# =====================================================================
#  PLANTILLA DE VARIABLES DE ENTORNO  -  AlertaU Web
#
#  LOCAL:  copia este archivo como  .env  y pon tus datos de MySQL local.
#  NUBE:   define estas mismas variables en el panel del hosting
#          (Railway / Render / etc.). NO subas el archivo .env (esta en .gitignore).
# =====================================================================

# --- Base de datos ---
# Valores por defecto para XAMPP en Windows (usuario root sin contrasena):
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=incidencias_campus
DB_PORT=3306

# Poner en true SOLO si el proveedor de BD exige TLS (Aiven, TiDB).
# En MySQL local (XAMPP) o en la red interna de Railway: false
DB_SSL=false

# --- Seguridad ---
# Clave para firmar la cookie de sesion del login web y los tokens JWT. Cambiala en produccion.
SECRET_KEY=ALERTAU2026$$**campus

# --- Correo SMTP (recuperacion de contrasena de la app movil, req. #3) ---
# Ejemplo con Gmail: crea una "contrasena de aplicacion" en tu cuenta Google.
# Si dejas esto vacio, la API genera el codigo pero NO envia el correo.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=tu_contrasena_de_aplicacion
SMTP_FROM=tucorreo@gmail.com
