# --- Python ---
__pycache__/
*.pyc
*.pyo

# --- Entornos virtuales ---
venv/
.venv/

# --- Variables de entorno (NUNCA subir credenciales) ---
.env

# --- Editores ---
.idea/
.vscode/

# --- Evidencias / fotos subidas por los usuarios en local ---
# Se conserva la carpeta y la imagen 'default' con un .gitkeep,
# pero no se suben las imagenes reales subidas durante las pruebas.
uploads/evidencias/*
!uploads/evidencias/.gitkeep
uploads/usuarios/*
!uploads/usuarios/.gitkeep
!uploads/**/default.png
